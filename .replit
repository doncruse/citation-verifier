run = "test -d .venv || (python -m venv .venv && .venv/bin/pip install --upgrade pip); .venv/bin/pip install -e '.[web]' && MODE=public .venv/bin/uvicorn web.app:app --host 0.0.0.0 --port 8080"
entrypoint = "web/app.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["cacert"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[agent]
expertMode = true

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "-m", "uvicorn", "web.app:app", "--host", "0.0.0.0", "--port", "5000"]
build = ["python3", "-m", "pip", "install", "-e", ".[web]"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m pip install -e '.[web]' && MODE=public python3 -m uvicorn web.app:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[userenv]

[userenv.shared]
MODE = "public"
